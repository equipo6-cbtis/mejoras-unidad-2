//Multiplicacion de tres numeros
#include <stdio.h>

int main (void)
{
	int num1, num2, num3, R;
	
	printf("introducir el primer numero");
	scanf("%d",&num1);
	printf("introducir el segundo numero");
	scanf("%d",&num2);
	printf("introduce el tercer numero");
	scanf("%d",&num3);
	R=num1*num2*num3;
	
	if (R>0){
		printf ("El resultado es %d positivo\n", R);
	}
	else if (R<0){
		printf("El resultado es %d negativo\n", R);
	}
	else {
		printf("El resultado es %d (es cero)\n", R);
	}
	
	return 0;
}


